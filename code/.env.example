# ============================================================
# Optionix Platform - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
ENVIRONMENT=production
LOG_LEVEL=INFO
VERSION=2.0.0
BUILD_DATE=
VCS_REF=

# Security (REQUIRED - generate strong random values)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-hex-string-in-production-do-it-now
# Must be exactly 32 characters
ENCRYPTION_KEY=A_32_CHAR_ENCRYPTION_KEY_HERE!!!

# Database (REQUIRED)
POSTGRES_PASSWORD=change-me-strong-postgres-password
DATABASE_URL=postgresql://optionix:${POSTGRES_PASSWORD}@postgres:5432/optionix

# Redis (REQUIRED)
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Grafana
GRAFANA_PASSWORD=change-me-grafana-admin-password

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Blockchain (optional)
ETHEREUM_PROVIDER_URL=https://mainnet.infura.io/v3/your-project-id
FUTURES_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ETHEREUM_CHAIN_ID=1

# ML Models
MODEL_PATH=ai_models/volatility_model.pkl
SCALER_PATH=ai_models/feature_scaler.pkl
MODEL_VERSION=1.0.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://optionix.com

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_WINDOW_MINUTES=1

# Financial limits
MAX_POSITION_SIZE=1000000.0
MIN_POSITION_SIZE=0.001
MAX_ORDER_SIZE=1000000.0

# Compliance flags
KYC_REQUIRED=true
AML_MONITORING_ENABLED=true
AUDIT_LOG_ENCRYPTION=true
