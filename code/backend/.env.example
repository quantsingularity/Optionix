# Optionix Backend Environment Configuration
# Copy this file to .env and fill in real values

# Application
ENVIRONMENT=development
DEBUG=false
APP_NAME=Optionix Trading Platform
APP_VERSION=2.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/optionix

# Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ENCRYPTION_KEY=ExactlyThirtyTwoCharKeyHere12345

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# Ethereum / Blockchain
ETHEREUM_PROVIDER_URL=https://mainnet.infura.io/v3/your-project-id
ETHEREUM_CHAIN_ID=1

# CORS
CORS_ORIGINS=http://localhost:3000,https://optionix.com

# Logging
LOG_LEVEL=INFO

# Model
MODEL_PATH=models/volatility_model.pkl
