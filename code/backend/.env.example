# =============================================================================
# Optionix Backend – Environment Variables
# Copy this file to .env and fill in real values before running.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Optionix Trading Platform"
APP_VERSION="2.0.0"
ENVIRONMENT=development          # development | staging | production | testing
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://optionix:password@localhost:5432/optionix
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be ≥ 32 chars; generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
# MUST be exactly 32 chars
ENCRYPTION_KEY=A_32_CHAR_DEFAULT_ENCRYPTION_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=200

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://optionix.com

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_PATH=models/volatility_model.pkl
SCALER_PATH=models/feature_scaler.pkl
MODEL_VERSION=1.0.0

# ── Blockchain (optional) ─────────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ETHEREUM_CHAIN_ID=1
FUTURES_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
